<%- include('partials/header') %>

<!-- 헤더 카드 -->
<div class="ss-myscore-header mb-3">
  <div class="ss-myscore-avatar">
    <i class="bi bi-person-fill"></i>
  </div>
  <div class="ss-myscore-user">
    <div class="ss-myscore-name"><%= userMember.name || '-' %>님의 라운딩</div>
    <div class="ss-myscore-sub">총 <%= stats.totalRounds %>라운드 참가</div>
  </div>
</div>

<!-- 스탯 카드 4개 -->
<div class="ss-stat-row mb-3">
  <div class="ss-stat-card">
    <span class="ss-stat-label">최근 스코어</span>
    <span class="ss-stat-val"><%= stats.recentScore || '-' %></span>
  </div>
  <div class="ss-stat-card">
    <span class="ss-stat-label">평균 스코어</span>
    <span class="ss-stat-val"><%= stats.avgScore || '-' %></span>
  </div>
  <div class="ss-stat-card">
    <span class="ss-stat-label">베스트</span>
    <span class="ss-stat-val"><%= stats.bestScore || '-' %></span>
  </div>
  <div class="ss-stat-card">
    <span class="ss-stat-label">1위 횟수</span>
    <span class="ss-stat-val"><%= stats.top1Count %>회</span>
  </div>
</div>

<!-- 라운딩 기록 -->
<div class="info-section mb-3">
  <div class="info-section-header">
    <span class="info-section-title">라운딩 기록</span>
    <span class="info-update-time"><%= stats.scoredRounds %>회 스코어 등록</span>
  </div>
  <% if (myRounds.length === 0) { %>
  <div class="text-center py-5 text-muted">
    <i class="bi bi-flag" style="font-size:2.5rem;"></i>
    <p class="mt-3 mb-0" style="font-size:var(--text-sm);">아직 참가한 라운딩이 없습니다.</p>
  </div>
  <% } else { %>
  <div class="course-list">
    <% myRounds.forEach(function(r) { %>
    <a href="/schedules/<%= r.scheduleId %>/results" class="course-row text-decoration-none">
      <div class="upcoming-cta-date" style="min-width:44px;">
        <span class="upcoming-cta-month"><%= moment(r.playDate).format('M') %>월</span>
        <span class="upcoming-cta-day"><%= moment(r.playDate).format('D') %></span>
        <span class="upcoming-cta-weekday"><%= moment(r.playDate).format('ddd') %></span>
      </div>
      <div class="course-row-info">
        <span class="course-row-name"><%= r.courseName %></span>
        <span class="course-row-sub">
          <% if (r.rank) { %>
          <%= r.rank %>위 / <%= r.totalPlayers %>명
          <% } else { %>
          스코어 미등록
          <% } %>
        </span>
      </div>
      <div class="d-flex flex-column align-items-end gap-1">
        <% if (r.score) { %>
        <span class="ss-round-score"><%= r.score %>타</span>
        <% if (r.rank === 1) { %>
        <span class="upcoming-cta-status upcoming-cta-status--open">1위</span>
        <% } %>
        <% } else { %>
        <span class="text-muted" style="font-size:var(--text-xs);">-</span>
        <% } %>
      </div>
    </a>
    <% }) %>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
